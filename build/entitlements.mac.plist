<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!--
      Hardened-runtime entitlements for Restream Chat Plus Plus.
      Electron needs JIT + unsigned-executable-memory for V8.
      Required for notarization on macOS 10.14+.
    -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <!-- Outbound network for OAuth + Restream chat WebSocket -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Inbound localhost callback for OAuth redirect on port 8765 -->
    <key>com.apple.security.network.server</key>
    <true/>
    <!--
      v0.1.66 — keychain access group for WebAuthn / passkey credentials
      (Ethan voice 3995, 2026-05-24). Codex xhigh review on the v0.1.65 fix
      flagged that `app.configureWebAuthn({ touchID })` is required for the
      macOS platform-authenticator (Touch ID / Secure Enclave) to surface
      the passkey sheet on accounts.google.com — without it, Electron 42
      returns `false` from `isUserVerifyingPlatformAuthenticatorAvailable()`
      and Google's WebAuthn JS aborts the ceremony silently.

      The `keychainAccessGroup` we pass to `app.configureWebAuthn` MUST
      match a value present in this entitlement. Format per Apple docs is
      `<TEAM_ID>.<BUNDLE_ID>.<arbitrary-suffix>`; we use the `.webauthn`
      suffix to keep the group dedicated to WebAuthn (Electron 42 only
      uses this for WebAuthn metadata + the per-session secret).

      Team ID T34G959ZG8 is the Developer ID team used by RC++ signing;
      bundle ID matches `appBundleId` in forge.config.ts. Changing either
      will break passkey storage AND credential lookup for any existing
      passkeys (device-bound, not iCloud-synced).
    -->
    <key>keychain-access-groups</key>
    <array>
      <string>T34G959ZG8.com.ethansk.restream-chat-plus-plus.webauthn</string>
    </array>
  </dict>
</plist>
